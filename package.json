{
  "name": "gist-blog",
  "version": "1.0.0",
  "description": "Static blog generator from GitHub gists",
  "type": "module",
  "main": "src/build.ts",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node src/build.ts",
    "postbuild": "node scripts/minify.ts",
    "dev": "npm run build && npx http-server dist -p 3000",
    "minify": "node scripts/minify.ts",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.client.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^16.2.1"
  },
  "devDependencies": {
    "@eslint/css": "^0.11.0",
    "@eslint/js": "^9.35.0",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.9",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "html-minifier-terser": "^7.2.0",
    "http-server": "^14.1.1",
    "sharp": "^0.34.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
